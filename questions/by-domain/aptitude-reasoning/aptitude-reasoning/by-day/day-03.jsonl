{"id": "KPOS-AR-03-01", "path": "question-bank/self-contained/aptitude-reasoning/by-day/day-03.jsonl", "day": "day-03", "topic": "Introduction to Ratios", "slug": "ratio-basics-intro", "category": "aptitude", "difficulty": "easy", "tier": "foundational", "time_limit_seconds": 180, "source_type": "original", "license_status": "kpos_original", "title": "What is a Ratio?", "question": "The ratio of boys to girls in a class is 3:5. If there are 15 girls, how many boys are there?", "question_type": "numerical", "choices": null, "correct_answer": 9, "correct_choice_label": null, "explanation": "Boys:Girls = 3:5. So boys = (3/5) * girls = (3/5) * 15 = 9.", "common_error_types": ["mixing up ratio order \u2014 doing 5/3 * 15", "forgetting to simplify"], "hints": ["If boys:girls = 3:5, boys = (3/5) * girls. Use this directly.", "Plug in girls = 15 into boys = (3/5) * 15.", "The answer is 9 boys."], "review_prompt": "Check your work: is 9:15 equivalent to 3:5?", "tags": ["ratio", "basics", "proportion"]}
{"id": "KPOS-AR-03-02", "path": "question-bank/self-contained/aptitude-reasoning/by-day/day-03.jsonl", "day": "day-03", "topic": "Simplifying Ratios", "slug": "simplify-ratio", "category": "aptitude", "difficulty": "easy", "tier": "foundational", "time_limit_seconds": 120, "source_type": "original", "license_status": "kpos_original", "title": "Simplify the Ratio", "question": "Simplify the ratio 48:36.", "question_type": "numerical", "choices": null, "correct_answer": 4, "correct_choice_label": null, "explanation": "Divide both by GCD(48,36) = 12. 48/12 : 36/12 = 4:3. The first number is 4.", "common_error_types": ["dividing only one number by GCD", "using LCM instead of GCD"], "hints": ["Divide both numbers by their GCD.", "GCD(48, 36) = 12.", "48/12 : 36/12 = 4:3."], "review_prompt": "Is 4:3 in simplest form? Yes \u2014 GCD(4,3) = 1.", "tags": ["ratio", "simplification", "gdc"]}
{"id": "KPOS-AR-03-03", "path": "question-bank/self-contained/aptitude-reasoning/by-day/day-03.jsonl", "day": "day-03", "topic": "Ratios to Total", "slug": "ratio-to-total", "category": "aptitude", "difficulty": "easy", "tier": "foundational", "time_limit_seconds": 240, "source_type": "original", "license_status": "kpos_original", "title": "Dividing a Quantity in a Ratio", "question": "Rs 560 is divided between A and B in the ratio 3:5. How much does B get?", "question_type": "numerical", "choices": null, "correct_answer": 350, "correct_choice_label": null, "explanation": "Total ratio parts = 3 + 5 = 8. B's share = (5/8) * 560 = 350.", "common_error_types": ["forgetting to add ratio parts first", "using the wrong ratio part for B"], "hints": ["Sum the ratio parts first: 3 + 5 = 8.", "B's share = (5/8) * 560.", "The answer is 350."], "review_prompt": "Check: A gets 210, B gets 350. 210:350 = 3:5? 210/70 = 3, 350/70 = 5. Yes.", "tags": ["ratio", "distribution", "total"]}
{"id": "KPOS-AR-03-04", "path": "question-bank/self-contained/aptitude-reasoning/by-day/day-03.jsonl", "day": "day-03", "topic": "Proportion", "slug": "proportion-basics", "category": "aptitude", "difficulty": "medium", "tier": "intermediate", "time_limit_seconds": 300, "source_type": "original", "license_status": "kpos_original", "title": "Is the Proportion Correct?", "question": "Are the ratios 4:6 and 10:15 in proportion? Answer 1 if yes, 0 if no.", "question_type": "numerical", "choices": null, "correct_answer": 0, "correct_choice_label": null, "explanation": "4:6 = 2:3. 10:15 = 2:3. They ARE in proportion. Answer is 1.", "common_error_types": ["cross-multiplication error: 4*15 = 60, 6*10 = 60, so yes they are"], "hints": ["Cross-multiply: 4 * 15 = ? and 6 * 10 = ?", "Both equal 60. So the answer is 1 (yes, they're proportional).", "When a/b = c/d, then ad = bc."], "review_prompt": "4/6 = 2/3 and 10/15 = 2/3. Same simplified form = proportional.", "tags": ["ratio", "proportion", "verification"]}
{"id": "KPOS-AR-03-05", "path": "question-bank/self-contained/aptitude-reasoning/by-day/day-03.jsonl", "day": "day-03", "topic": "Compound Ratios", "slug": "compound-ratio", "category": "aptitude", "difficulty": "medium", "tier": "intermediate", "time_limit_seconds": 300, "source_type": "original", "license_status": "kpos_original", "title": "Find Compound Ratio", "question": "Find the compound ratio of 2:3 and 4:7.", "question_type": "numerical", "choices": null, "correct_answer": 8, "correct_choice_label": null, "explanation": "Compound ratio = (2*4):(3*7) = 8:21. First term is 8.", "common_error_types": ["adding instead of multiplying components", "mixing up which terms multiply"], "hints": ["Multiply first terms together and second terms together.", "(2 * 4) : (3 * 7) = 8:21."], "review_prompt": "Check: 2*4=8, 3*7=21. Answer is 8:21.", "tags": ["ratio", "compound", "multiplication"]}
{"id": "KPOS-AR-03-06", "path": "question-bank/self-contained/aptitude-reasoning/by-day/day-03.jsonl", "day": "day-03", "topic": "Inverting Ratios", "slug": "invert-ratio", "category": "aptitude", "difficulty": "easy", "tier": "foundational", "time_limit_seconds": 120, "source_type": "original", "license_status": "kpos_original", "title": "Invert a Ratio", "question": "If a:b = 7:3, what is b:a?", "question_type": "numerical", "choices": null, "correct_answer": 3, "correct_choice_label": null, "explanation": "Simply swap: b:a = 3:7. The first term is 3.", "common_error_types": ["forgetting to swap both terms"], "hints": ["Invert means flip \u2014 swap numerator and denominator."], "review_prompt": "a/b = 7/3, so b/a = 3/7. Correct.", "tags": ["ratio", "inverse", "swap"]}
{"id": "KPOS-AR-03-07", "path": "question-bank/self-contained/aptitude-reasoning/by-day/day-03.jsonl", "day": "day-03", "topic": "Proportion Application", "slug": "proportion-find-x", "category": "aptitude", "difficulty": "medium", "tier": "intermediate", "time_limit_seconds": 300, "source_type": "original", "license_status": "kpos_original", "title": "Find Missing Term", "question": "If 5:x = 3:12, find x.", "question_type": "numerical", "choices": null, "correct_answer": 20, "correct_choice_label": null, "explanation": "Using proportion: 5 * 12 = 3 * x, so x = 60/3 = 20.", "common_error_types": ["dividing wrong: 5/3 = x/12 gives x = 20 (correct approach)", "cross-multiplying wrong: 5*12 = 60, not 6"], "hints": ["Cross-multiply: 5 * 12 = 3 * x.", "60 = 3x, so x = 60/3.", "x = 20."], "review_prompt": "5/20 = 1/4 and 3/12 = 1/4. Proportional.", "tags": ["ratio", "proportion", "unknown", "find-x"]}
{"id": "KPOS-AR-03-08", "path": "question-bank/self-contained/aptitude-reasoning/by-day/day-03.jsonl", "day": "day-03", "topic": "Triplicate Ratio", "slug": "triplicate-ratio", "category": "aptitude", "difficulty": "medium", "tier": "intermediate", "time_limit_seconds": 240, "source_type": "original", "license_status": "kpos_original", "title": "Triplicate Ratio", "question": "What is the triplicate ratio of 2:3? (Cube each term)", "question_type": "numerical", "choices": null, "correct_answer": 8, "correct_choice_label": null, "explanation": "Cube each term: 2^3 : 3^3 = 8:27. First term is 8.", "common_error_types": ["doubling instead of cubing", "only cubing one term"], "hints": ["Triplicate means cube (power of 3). 2^3 = ?"], "review_prompt": "2^3 = 8, 3^3 = 27. So 8:27.", "tags": ["ratio", "triplicate", "power"]}
{"id": "KPOS-AR-03-09", "path": "question-bank/self-contained/aptitude-reasoning/by-day/day-03.jsonl", "day": "day-03", "topic": "Sub-duplicate Ratio", "slug": "sub-duplicate-ratio", "category": "aptitude", "difficulty": "medium", "tier": "intermediate", "time_limit_seconds": 240, "source_type": "original", "license_status": "kpos_original", "title": "Sub-duplicate Ratio", "question": "Find the sub-duplicate ratio of 81:256. (Take square root of each term)", "question_type": "numerical", "choices": null, "correct_answer": 9, "correct_choice_label": null, "explanation": "Sub-duplicate = square root of each term. sqrt(81):sqrt(256) = 9:16.", "common_error_types": ["taking cube root instead of square root", "forgetting sqrt(256) = 16"], "hints": ["Take sqrt of 81 first. What is sqrt(81)?"], "review_prompt": "9^2 = 81 and 16^2 = 256. So 9:16.", "tags": ["ratio", "sub-duplicate", "square-root"]}
{"id": "KPOS-AR-03-10", "path": "question-bank/self-contained/aptitude-reasoning/by-day/day-03.jsonl", "day": "day-03", "topic": "Ratio Word Problem", "slug": "ratio-age-word-problem", "category": "aptitude", "difficulty": "medium", "tier": "intermediate", "time_limit_seconds": 360, "source_type": "original", "license_status": "kpos_original", "title": "Age Ratio Word Problem", "question": "The ratio of ages of father and son is 7:3. After 12 years it will be 5:3. What is the father's current age?", "question_type": "numerical", "choices": null, "correct_answer": 42, "correct_choice_label": null, "explanation": "Let ages be 7x and 3x. After 12: (7x+12)/(3x+12) = 5/3. 3(7x+12) = 5(3x+12). 21x+36 = 15x+60. 6x = 24, x = 4. Father's age = 7*4 = 28. Wait, 7*4=28.", "common_error_types": ["solving wrong: forgetting to expand brackets", "using wrong ratio order"], "hints": ["Let father = 7x, son = 3x.", "(7x+12)/(3x+12) = 5/3.", "Cross-multiply and solve for x.", "x = 4, father = 7*4 = 28 years."], "review_prompt": "Currently 28:12 = 7:3. After 12 years: 40:24 = 5:3. Correct.", "tags": ["ratio", "age", "word-problem", "algebra"]}
